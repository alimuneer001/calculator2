# Copy this file to ".env" and fill in your own values.

# Server
PORT=5000
# The frontend URL that is allowed to call this API (CORS).
CLIENT_URL=http://localhost:5173

# Database connection URL
#   Format:  postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/calculator_db
# Set to "true" when using a hosted DB (Neon/Supabase/Render/Railway), else "false".
DB_SSL=false

# JWT (use a long random string for JWT_SECRET in production)
JWT_SECRET=super_secret_change_me
JWT_EXPIRES_IN=7d
